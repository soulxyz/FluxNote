# Git archive export-ignore rules
# 以下路径在 git archive 打包时会被自动排除（用于 Release 发布包）

# 虚拟环境
venv/           export-ignore
.venv/          export-ignore

# 本地数据与上传文件（不应随代码发布）
data/           export-ignore
uploads/        export-ignore

# Python 缓存
__pycache__/    export-ignore
*.py[cod]       export-ignore
*.pyo           export-ignore

# 数据库文件
*.db            export-ignore
*.db-journal    export-ignore
*.sqlite3       export-ignore

# 开发工具配置
.vscode/        export-ignore
.idea/          export-ignore
.cursor/        export-ignore
.claude/        export-ignore
.gemini/        export-ignore

# GitHub Actions（发布包的使用者不需要 CI 配置）
.github/        export-ignore

# 环境变量
.env            export-ignore
.env.*          export-ignore
.flaskenv       export-ignore

# 测试与覆盖率
.pytest_cache/  export-ignore
.mypy_cache/    export-ignore
.coverage       export-ignore
htmlcov/        export-ignore

# 脚本工具（可选排除，开发辅助脚本）
scripts/        export-ignore

# 预览图（仅用于展示，运行时非必需）
**/preview.png  export-ignore
**/preview.jpg  export-ignore

# 其他
*.log           export-ignore
.DS_Store       export-ignore
Thumbs.db       export-ignore
GEMINI.md       export-ignore

# 文本文件统一换行符（跨平台一致性）
*.py            text eol=lf
*.js            text eol=lf
*.css           text eol=lf
*.html          text eol=lf
*.md            text eol=lf
*.yml           text eol=lf
*.yaml          text eol=lf
*.txt           text eol=lf
*.json          text eol=lf
